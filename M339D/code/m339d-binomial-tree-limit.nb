Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"lots", " ", "of", " ", "periods"}], " ", "*)"}], " ", 
  RowBox[{
   RowBox[{
    RowBox[{"n", "=", "100"}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"length", " ", "of", " ", "every", " ", "period"}], " ", "*)"}], 
    " ", 
    RowBox[{"h", "=", 
     RowBox[{"T", "/", "n"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"up", " ", "factor"}], " ", "*)"}], " ", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "\[Delta]"}], ")"}], "*", "h"}], "+", 
        RowBox[{"\[Sigma]", "*", 
         RowBox[{"Sqrt", "[", "h", "]"}]}]}], ")"}]}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"down", " ", "factor"}], " ", "*)"}], " ", 
    RowBox[{"d", " ", "=", " ", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "\[Delta]"}], ")"}], "*", "h"}], "-", 
        RowBox[{"\[Sigma]", "*", 
         RowBox[{"Sqrt", "[", "h", "]"}]}]}], ")"}]}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"\"\<true\>\"", " ", "probability"}], " ", "*)"}], 
    RowBox[{"p", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Alpha]", "-", "\[Delta]"}], ")"}], "*", "h"}], ")"}]}],
         "-", "d"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"u", "-", "d"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"even", " ", "more", " ", "simulated", " ", "paths"}], " ", 
    "*)"}], 
   RowBox[{
    RowBox[{"nsim", "=", "1000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"drawing", " ", "Bernoulli", " ", "trials"}], " ", "*)"}], " ", 
   RowBox[{
    RowBox[{"LBernSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"RandomVariate", "[", 
        RowBox[{
         RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", "n"}], "]"}], 
       ",", " ", 
       RowBox[{"{", "nsim", "}"}]}], "]"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"cointosses", " ", "from", " ", "Bernoulli", " ", "trials"}], 
     " ", "*)"}], " ", 
    RowBox[{"LCoinTossSims", "=", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", "*", "LBernSims"}]}]}], " ", ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"prepending", " ", "the", " ", "origin"}], " ", "*)"}], " ", 
    RowBox[{"LWalkSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Prepend", "[", 
        RowBox[{
         RowBox[{"Accumulate", "[", 
          RowBox[{"LCoinTossSims", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]",
    " ", 
   RowBox[{"(*", " ", 
    RowBox[{"plotting", " ", "the", " ", "walk"}], " ", "*)"}], " ", 
   RowBox[{
    RowBox[{"PlotFormat", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"WalkToPlot", "[", 
        RowBox[{"LWalkSims", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], ";", "  ", 
    RowBox[{"ListLinePlot", "[", "PlotFormat", "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.68302368123774*^9, 3.683023698743587*^9}, {
   3.6830237303070383`*^9, 3.68302373153515*^9}, 3.6830237711373663`*^9, {
   3.683023836715809*^9, 3.6830238383754683`*^9}, 3.683032607691992*^9},
 CellLabel->"In[26]:=",ExpressionUUID->"5b02ce56-21f3-4068-921f-4f0d2b782685"],

