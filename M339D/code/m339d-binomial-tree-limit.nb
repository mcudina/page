Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"more", " ", "simulated", " ", "paths"}], " ", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"nsim", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"drawing", " ", "Bernoulli", " ", "trials"}], " ", "*)"}], " ", 
   RowBox[{
    RowBox[{"LBernSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"RandomVariate", "[", 
        RowBox[{
         RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", "n"}], "]"}], 
       ",", " ", 
       RowBox[{"{", "nsim", "}"}]}], "]"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"cointosses", " ", "from", " ", "Bernoulli", " ", "trials"}], 
     " ", "*)"}], " ", 
    RowBox[{"LCoinTossSims", "=", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", "*", "LBernSims"}]}]}], " ", ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"prepending", " ", "the", " ", "origin"}], " ", "*)"}], " ", 
    RowBox[{"LWalkSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Prepend", "[", 
        RowBox[{
         RowBox[{"Accumulate", "[", 
          RowBox[{"LCoinTossSims", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]",
    " ", 
   RowBox[{"(*", " ", 
    RowBox[{"plotting", " ", "the", " ", "walk"}], " ", "*)"}], " ", 
   RowBox[{
    RowBox[{"PlotFormat", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"WalkToPlot", "[", 
        RowBox[{"LWalkSims", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], ";", "  ", 
    RowBox[{"ListLinePlot", "[", "PlotFormat", "]"}]}], "\[IndentingNewLine]",
    "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.683021564928411*^9, 3.683021564934842*^9}, {
