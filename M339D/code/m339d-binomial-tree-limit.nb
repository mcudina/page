Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"What", " ", "are", " ", "the", " ", "simulated", " ", 
    RowBox[{"returns", "?"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{"height", " ", "of", " ", "the", " ", "final", " ", "position"}], 
   " ", "*)"}], " ", 
  RowBox[{
   RowBox[{
    RowBox[{"htSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"LWalkSims", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", 
          RowBox[{"n", "+", "1"}]}], "]"}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"number", " ", "of", " ", "steps", " ", "up"}], " ", "*)"}], " ", 
    RowBox[{"upstepsSims", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"htSims", "+", "n"}], ")"}], "/", "2"}]}], ";", 
    RowBox[{"(*", " ", 
     RowBox[{"number", " ", "of", " ", "steps", " ", "down"}], " ", "*)"}], 
    " ", 
    RowBox[{"downstepsSims", "=", " ", 
     RowBox[{"n", "-", "upstepsSims"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{
     "from", " ", "cointosses", " ", "to", " ", "realized", " ", "returns"}], 
     " ", "*)"}], " ", 
    RowBox[{"ReturnSims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Log", "[", 
        RowBox[{
         RowBox[{"u", "^", 
          RowBox[{"upstepsSims", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}], "*", 
         RowBox[{"d", "^", 
          RowBox[{"downstepsSims", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], " ", ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "histogram", " ", "of", " ", "simulated", " ", "realized", " ", 
     "returns"}], " ", "*)"}], " ", 
   RowBox[{"Histogram", "[", 
    RowBox[{"ReturnSims", ",", 
     RowBox[{"bspec", "=", "50"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"hatalpha", "=", 
    RowBox[{"Mean", "[", "ReturnSims", "]"}]}]}]}]], "Input",
 CellChangeTimes->{
  3.6830226079919558`*^9, {3.683022867286524*^9, 3.683022878176504*^9}, {
   3.683022937228039*^9, 3.6830230729784517`*^9}, {3.683023179074293*^9, 
