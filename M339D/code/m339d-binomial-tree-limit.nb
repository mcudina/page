Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"length", " ", "of", " ", "every", " ", "period"}], " ", "*)"}], 
  " ", 
  RowBox[{
   RowBox[{
    RowBox[{"h", "=", 
     RowBox[{"T", "/", "n"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"up", " ", "factor"}], " ", "*)"}], " ", 
    RowBox[{"u", " ", "=", " ", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "\[Delta]"}], ")"}], "*", "h"}], "+", 
        RowBox[{"\[Sigma]", "*", 
         RowBox[{"Sqrt", "[", "h", "]"}]}]}], ")"}]}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"down", " ", "factor"}], " ", "*)"}], " ", 
    RowBox[{"d", " ", "=", " ", 
     RowBox[{"E", "^", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"r", "-", "\[Delta]"}], ")"}], "*", "h"}], "-", 
        RowBox[{"\[Sigma]", "*", 
         RowBox[{"Sqrt", "[", "h", "]"}]}]}], ")"}]}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"\"\<true\>\"", " ", "probability"}], " ", "*)"}], 
    RowBox[{"p", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"E", "^", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Alpha]", "-", "\[Delta]"}], ")"}], "*", "h"}], ")"}]}],
         "-", "d"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"u", "-", "d"}], ")"}]}]}]}], 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"drawing", " ", "the", " ", "trees", " ", "of", " ", "up"}], 
      "&"}], "down", " ", "steps", " ", "under", " ", "the", 
     " ", "\"\<true\>\"", " ", "probability"}], " ", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"drawing", " ", "Bernoulli", " ", "trials"}], " ", "*)"}], " ", 
   RowBox[{
    RowBox[{"LBern", "=", 
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", "n"}], "]"}]}], 
    ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"cointosses", " ", "from", " ", "Bernoulli", " ", "trials"}], 
     " ", "*)"}], " ", 
    RowBox[{"LCoinToss", "=", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      RowBox[{"2", "*", "LBern"}]}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"prepending", " ", "the", " ", "origin"}], " ", "*)"}], " ", 
    RowBox[{"LWalk", "=", 
     RowBox[{"Prepend", "[", 
      RowBox[{
       RowBox[{"Accumulate", "[", "LCoinToss", "]"}], ",", "0"}], "]"}]}], ";",
     " ", 
    RowBox[{"(*", " ", 
     RowBox[{"plotting", " ", "the", " ", "walk"}], " ", "*)"}], " ", 
    RowBox[{
     RowBox[{"WalkToPlot", "[", "w_", "]"}], ":=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"i", "-", "1"}], ",", 
         RowBox[{"w", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Length", "[", "w", "]"}]}], "}"}]}], "]"}]}], ";", " ", 
    RowBox[{"WalkToPlot", "[", "LWalk", "]"}], ";", " ", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{"WalkToPlot", "[", "LWalk", "]"}], "]"}]}]}]}]], "Input",
