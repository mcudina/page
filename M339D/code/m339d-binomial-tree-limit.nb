Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"What", " ", "are", " ", "the", " ", "simulated", " ", "stock", " ", 
    RowBox[{"prices", "?"}]}], " ", "*)"}], " ", 
  RowBox[{
   RowBox[{
    RowBox[{"S0", "=", "100"}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{
     "from", " ", "cointosses", " ", "to", " ", "stock", " ", "prices"}], " ",
      "*)"}], " ", 
    RowBox[{"S1Sims", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"S0", "*", 
        RowBox[{"u", "^", 
         RowBox[{"upstepsSims", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "*", 
        RowBox[{"d", "^", 
         RowBox[{"downstepsSims", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}]}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "nsim"}], "}"}]}], "]"}]}], " ", ";", 
    RowBox[{"(*", " ", 
     RowBox[{
     "histogram", " ", "of", " ", "simulated", " ", "stock", " ", "prices"}], 
     " ", "*)"}], " ", 
    RowBox[{"Histogram", "[", 
     RowBox[{"S1Sims", ",", 
      RowBox[{"bspec", "=", "50"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"Mean", "[", "S1Sims", "]"}], "\[IndentingNewLine]"}]}]], "Input",
